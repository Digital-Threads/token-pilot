# Dependencies
node_modules/

# Build output
dist/
# Exceptions: agents + skills are plugin-loaded (see .claude-plugin/plugin.json
# "agents" / "skills" fields), so they must be versioned. dist/agents/ holds
# the composed tp-* .md files with shared preamble; without them, Claude Code
# plugin install reads an empty agents/ dir and shows "no skills or agents".
!dist/agents/
!dist/agents/**
coverage/

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Environment
.env
.env.*

# Token Pilot managed binaries
.token-pilot/

# Internal docs (RND/SDD)
docs/rnd.md
docs/sdd.md
docs/code-review-report.md

# MCP Registry auth tokens
.mcpregistry_*

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
